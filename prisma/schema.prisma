// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// MODULE 1: Identity & Authentication (Auth.js Compatible)
// ==========================================

model User {
  id            String    @id @default(uuid()) @db.Uuid
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String? // For credentials-based authentication
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  userProgress UserProgress?
  accounts     Account[]
  sessions     Session[]
  quizAttempts QuizAttempt[]
}

model UserProgress {
  id            String    @id @default(uuid()) @db.Uuid
  userId        String    @unique @db.Uuid
  username      String?   @unique
  xp            Int       @default(0)
  level         Int       @default(1)
  currentStreak Int       @default(0)
  bestStreak    Int       @default(0)
  lastActiveAt  DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([xp(desc)]) // Leaderboard lookup index
}

model Account {
  id                       String  @id @default(uuid()) @db.Uuid
  userId                   String  @db.Uuid
  type                     String
  provider                 String
  providerAccountId        String
  refresh_token            String? @db.Text
  access_token             String? @db.Text
  expires_at               Int?
  token_type               String?
  scope                    String?
  id_token                 String? @db.Text
  session_state            String?
  refresh_token_expires_in Int? // Required for Twitter / Slack OAuth providers

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid()) @db.Uuid
  sessionToken String   @unique
  userId       String   @db.Uuid
  expires      DateTime

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ==========================================
// MODULE 2: Geography Core
// ==========================================

enum Continent {
  AFRICA
  ANTARCTICA
  ASIA
  EUROPE
  NORTH_AMERICA
  OCEANIA
  SOUTH_AMERICA
}

model Country {
  id           String            @id @default(uuid()) @db.Uuid
  name         String
  officialName String
  slug         String            @unique
  region       String?
  iso2         String            @unique
  iso3         String            @unique
  capital      String[] // PostgreSQL text array to support multiple or disputed capitals
  continent    Continent
  flagEmoji    String
  flagSvg      String // Stores the asset name/path rather than complete URLs to ensure portability
  isActive     Boolean           @default(true) // Aligns with User.isActive consistency
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  // Relations
  detail       CountryDetail?
  currencies   CountryCurrency[]
  languages    CountryLanguage[]
  trivia       CountryTrivia[]
  questions    Question[]
  quizzes      Quiz[]
  sortOrder    Int               @default(0)

  @@index([name])
  @@index([slug])
}

model CountryDetail {
  id           String   @id @default(uuid()) @db.Uuid
  countryId    String   @unique @db.Uuid
  population   BigInt? // Using BigInt for future-proofing and avoiding 32-bit integer overflows
  areaKm2      Float?
  timezones    String[]
  callingCodes String[]
  internetTld  String?
  drivingSide  String?
  latitude     Float?
  longitude    Float?
  description  String?  @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  country Country @relation(fields: [countryId], references: [id], onDelete: Cascade)
}

model Currency {
  id     String @id @default(uuid()) @db.Uuid
  code   String @unique
  name   String
  symbol String

  // Relations
  countries CountryCurrency[]
}

model CountryCurrency {
  countryId  String @db.Uuid
  currencyId String @db.Uuid

  // Relations
  country  Country  @relation(fields: [countryId], references: [id], onDelete: Cascade)
  currency Currency @relation(fields: [currencyId], references: [id], onDelete: Cascade)

  @@id([countryId, currencyId])
  @@index([currencyId]) // Optimizes reverse lookups from Currency -> Country
}

model Language {
  id   String @id @default(uuid()) @db.Uuid
  code String @unique
  name String

  // Relations
  countries CountryLanguage[]
}

model CountryLanguage {
  countryId  String  @db.Uuid
  languageId String  @db.Uuid
  isOfficial Boolean @default(false)

  // Relations
  country  Country  @relation(fields: [countryId], references: [id], onDelete: Cascade)
  language Language @relation(fields: [languageId], references: [id], onDelete: Cascade)

  @@id([countryId, languageId])
  @@index([languageId]) // Optimizes reverse lookups from Language -> Country
}

model CountryTrivia {
  id           String   @id @default(uuid()) @db.Uuid
  countryId    String   @db.Uuid
  title        String
  fact         String   @db.Text
  displayOrder Int      @default(0)
  isPublished  Boolean  @default(true) // Allows draft trivia facts to be written and managed safely
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  country Country @relation(fields: [countryId], references: [id], onDelete: Cascade)

  @@index([countryId]) // Optimizes lookup of trivia items by country
}

// ==========================================
// MODULE 3: Question Bank
// ==========================================

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum QuestionType {
  MULTIPLE_CHOICE
  TRUE_FALSE
  TEXT_INPUT
  IMAGE_CHOICE
}

model Category {
  id           String   @id @default(uuid()) @db.Uuid
  name         String   @unique
  slug         String   @unique
  description  String?  @db.Text
  icon         String?
  color        String?
  displayOrder Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  questions Question[]
  quizzes   Quiz[]

  @@index([displayOrder])
}

model Question {
  id                   String       @id @default(uuid()) @db.Uuid
  categoryId           String       @db.Uuid
  countryId            String?      @db.Uuid
  question             String       @db.Text
  questionType         QuestionType @default(MULTIPLE_CHOICE)
  explanation          String?      @db.Text
  explanationImagePath String? // Stores relative asset path for explanations
  hint                 String?      @db.Text
  imagePath            String? // Stores relative asset path for the question (e.g., flags/map highlights)
  difficulty           Difficulty
  points               Int          @default(10)
  timeLimitSeconds     Int          @default(20)
  isActive             Boolean      @default(true)
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  // Relations
  category      Category         @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  country       Country?         @relation(fields: [countryId], references: [id], onDelete: SetNull)
  options       QuestionOption[]
  quizQuestions QuizQuestion[]
  quizAnswers   QuizAnswer[]

  @@index([categoryId])
  @@index([countryId])
  @@index([difficulty])
  @@index([isActive])
}

model QuestionOption {
  id           String   @id @default(uuid()) @db.Uuid
  questionId   String   @db.Uuid
  text         String?  @db.Text // Nullable to support image-only options without dummy text
  imagePath    String? // Stores relative asset path for option images
  isCorrect    Boolean
  displayOrder Int      @default(0) // Default simplifies insertions
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  question    Question     @relation(fields: [questionId], references: [id], onDelete: Cascade)
  quizAnswers QuizAnswer[]

  @@unique([questionId, displayOrder]) // Enforces display order uniqueness within each question
  @@index([questionId])
}

// ==========================================
// MODULE 4: Quiz Engine
// ==========================================

enum QuizType {
  DAILY
  COUNTRY
  CATEGORY
  MIXED
  CUSTOM
}

enum QuizStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model Quiz {
  id               String      @id @default(uuid()) @db.Uuid
  title            String
  slug             String      @unique
  description      String?     @db.Text
  quizType         QuizType
  status           QuizStatus  @default(DRAFT) // Better state tracking than boolean flags
  categoryId       String?     @db.Uuid
  countryId        String?     @db.Uuid
  difficulty       Difficulty?
  totalQuestions   Int
  timeLimitSeconds Int?
  passingScore     Int         @default(70)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  // Relations
  category  Category?      @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  country   Country?       @relation(fields: [countryId], references: [id], onDelete: SetNull)
  questions QuizQuestion[]
  attempts  QuizAttempt[]

  @@index([quizType])
  @@index([categoryId])
  @@index([countryId])
  @@index([status])
}

model QuizQuestion {
  id           String   @id @default(uuid()) @db.Uuid
  quizId       String   @db.Uuid
  questionId   String   @db.Uuid
  displayOrder Int
  createdAt    DateTime @default(now())

  // Relations
  quiz     Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Restrict)

  @@unique([quizId, questionId])
  @@unique([quizId, displayOrder])
  @@index([quizId])
  @@index([questionId])
}

model QuizAttempt {
  id               String      @id @default(uuid()) @db.Uuid
  userId           String?     @db.Uuid
  quizId           String      @db.Uuid

  score            Int         @default(0)
  totalQuestions   Int
  correctAnswers   Int         @default(0)
  wrongAnswers     Int         @default(0)
  percentage       Float       @default(0)

  startedAt        DateTime    @default(now())
  completedAt      DateTime?
  timeTakenSeconds Int?

  isCompleted      Boolean     @default(false)
  isGuest          Boolean     @default(false)

  difficulty       Difficulty?

  // Relations
  user             User?        @relation(fields: [userId], references: [id], onDelete: Restrict)
  quiz             Quiz         @relation(fields: [quizId], references: [id], onDelete: Restrict)
  answers          QuizAnswer[]

  @@index([userId])
  @@index([quizId])
  @@index([startedAt])
  @@index([isCompleted])
  @@index([isGuest])
}

model QuizAnswer {
  id               String   @id @default(uuid()) @db.Uuid
  quizAttemptId    String   @db.Uuid
  questionId       String   @db.Uuid
  selectedOptionId String?  @db.Uuid
  textAnswer       String?  @db.Text
  isCorrect        Boolean
  answeredAt       DateTime @default(now())

  // Relations
  quizAttempt    QuizAttempt     @relation(fields: [quizAttemptId], references: [id], onDelete: Cascade)
  question       Question        @relation(fields: [questionId], references: [id], onDelete: Restrict)
  selectedOption QuestionOption? @relation(fields: [selectedOptionId], references: [id], onDelete: SetNull)

  @@unique([quizAttemptId, questionId])
  @@index([quizAttemptId])
  @@index([questionId])
}
